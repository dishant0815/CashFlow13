# CashFlow13 — env vars are NOT required for the seeded demo.
# These are only used by the live API routes (/api/categorize,
# /api/explain) and the optional regen scripts in scripts/.

# Google Gemini (free tier). Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Optional: override the default model. Defaults to gemini-2.5-flash.
GEMINI_MODEL=gemini-2.5-flash

# Plaid (sandbox) — only if you swap out the mock Plaid Link
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# Supabase — only if you wire up persistence
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
